---
import BaseLayout from "../layouts/BaseLayout.astro";
import { faqPageContent } from "../data/faqPages";
import { instagramLink, whatsappLink, type SiteLang } from "../data/site";

const { lang } = Astro.props as { lang: SiteLang };
const content = faqPageContent[lang];
const isEn = lang === "en";
const baseLangPill = "rounded-full border border-white/10 px-3 py-1 hover:bg-white/5";
const activeLangPill = "text-white";

const structuredData = [
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    mainEntity: content.items.map((item) => ({
      "@type": "Question",
      name: item.question,
      acceptedAnswer: {
        "@type": "Answer",
        text: item.answer,
      },
    })),
  },
];
---

<BaseLayout lang={lang} title={content.seo.title} description={content.seo.description} ogImage={content.seo.ogImage} structuredData={structuredData}>
  <main class="mx-auto max-w-5xl px-4 pb-20">
    <div class="sticky-header pointer-events-none fixed left-0 right-0 top-0 z-[60] hidden" data-sticky-header data-hide-on-lightbox>
      <div class="mx-auto max-w-6xl px-4 pt-3">
        <div class="pointer-events-auto relative flex items-center gap-4 rounded-full glass-strong px-4 py-2">
          <a href={lang === "es" ? "/" : "/en/"} class="shrink-0 text-sm font-semibold tracking-wide text-glass">Vigarartattoo</a>
          <nav class="hidden min-w-0 flex-1 items-center justify-center gap-3 text-sm text-zinc-200 md:flex text-glass">
            <a class="nav-pill hover:text-white border border-transparent rounded-full px-2 py-1" href={lang === "es" ? "/" : "/en/"}>{lang === "es" ? "Inicio" : "Home"}</a>
            <a class="nav-pill hover:text-white border border-transparent rounded-full px-2 py-1" href={lang === "es" ? "/works" : "/en/works"}>{lang === "es" ? "Trabajos" : "Works"}</a>
            <a class="nav-pill hover:text-white border border-transparent rounded-full px-2 py-1" href={lang === "es" ? "/cuidados-tatuaje" : "/en/tattoo-aftercare"}>{lang === "es" ? "Cuidados" : "Aftercare"}</a>
          </nav>
          <div class="ml-auto flex shrink-0 items-center gap-2">
            <a data-lang-link="es" class={`${baseLangPill} ${!isEn ? activeLangPill : ""}`} href="/" aria-current={!isEn ? "page" : undefined}>ES</a>
            <a data-lang-link="en" class={`${baseLangPill} ${isEn ? activeLangPill : ""}`} href="/en/" aria-current={isEn ? "page" : undefined}>EN</a>
            <a class="rounded-full border border-white/15 bg-white/5 px-3 py-1.5 text-sm font-semibold text-white hover:bg-white/10" href={whatsappLink} target="_blank" rel="noreferrer">{lang === "es" ? "Reservar" : "Book"}</a>
          </div>
        </div>
      </div>
    </div>

    <header class="relative flex items-center justify-between py-6">
      <a href={lang === "es" ? "/" : "/en/"} class="text-lg font-semibold tracking-wide">Vigarartattoo</a>
      <nav class="hidden items-center gap-6 text-sm text-zinc-300 md:flex">
        <a class="hover:text-white" href={lang === "es" ? "/" : "/en/"}>{lang === "es" ? "Inicio" : "Home"}</a>
        <a class="hover:text-white" href={lang === "es" ? "/works" : "/en/works"}>{lang === "es" ? "Trabajos" : "Works"}</a>
      </nav>
      <a class="rounded-full bg-white px-4 py-2 text-sm font-semibold text-zinc-950 hover:bg-zinc-200" href={whatsappLink} target="_blank" rel="noreferrer">{lang === "es" ? "Reservar" : "Book"}</a>
    </header>

    <section class="relative overflow-hidden rounded-3xl border border-white/10 bg-zinc-950 px-6 py-14 md:px-12 md:py-18">
      <div class="absolute inset-0 bg-[radial-gradient(circle_at_top_left,rgba(255,255,255,0.12),transparent_45%),linear-gradient(135deg,rgba(255,255,255,0.08),transparent_60%)]"></div>
      <div class="relative">
        <p class="text-xs uppercase tracking-[0.35em] text-zinc-300/80">{content.hero.eyebrow}</p>
        <h1 class="mt-4 max-w-4xl text-4xl font-semibold leading-tight text-white md:text-6xl">{content.hero.title}</h1>
        <p class="mt-6 max-w-3xl text-base leading-relaxed text-zinc-200 md:text-lg">{content.hero.description}</p>
      </div>
    </section>

    <section class="reveal pb-16 pt-10">
      <div class="rounded-3xl border border-white/10 bg-white/5 p-8 md:p-10">
        {content.intro.map((paragraph) => (
          <p class="mt-5 first:mt-0 text-sm leading-relaxed text-zinc-300 md:text-base">{paragraph}</p>
        ))}
      </div>
    </section>

    <section class="reveal pb-16">
      <div class="grid gap-4 md:grid-cols-2">
        {content.items.map((item) => (
          <article class="rounded-2xl border border-white/10 bg-white/5 p-6">
            <h2 class="text-lg font-semibold text-white">{item.question}</h2>
            <p class="mt-3 text-sm leading-relaxed text-zinc-300">{item.answer}</p>
          </article>
        ))}
      </div>
    </section>

    <section class="reveal pb-16">
      <div class="grid gap-6 lg:grid-cols-[1fr_0.9fr]">
        <div class="rounded-3xl border border-white/10 bg-gradient-to-br from-white/7 to-white/[0.03] p-8 md:p-10">
          <h2 class="text-2xl font-semibold md:text-3xl">{content.relatedTitle}</h2>
          <div class="mt-6 space-y-3">
            {content.related.map((link) => (
              <a class="flex items-center justify-between border-b border-white/10 pb-3 text-sm text-zinc-200 transition hover:text-white" href={link.href}>
                <span>{link.label}</span>
                <span class="text-zinc-500">→</span>
              </a>
            ))}
          </div>
        </div>

        <div class="rounded-3xl border border-white/10 bg-white/5 p-8 md:p-10">
          <h2 class="text-2xl font-semibold md:text-3xl">{lang === "es" ? "¿Sigues con dudas?" : "Still have questions?"}</h2>
          <p class="mt-4 text-sm leading-relaxed text-zinc-300 md:text-base">
            {lang === "es"
              ? "Si tienes una idea concreta o quieres comentar tu caso antes de reservar, puedes escribir directamente y recibir orientación personalizada."
              : "If you have a specific idea or want to discuss your case before booking, you can send a direct message and get personal guidance."}
          </p>
          <div class="mt-6 flex flex-wrap gap-3">
            <a class="rounded-full bg-white px-4 py-2 text-sm font-semibold text-zinc-950 hover:bg-zinc-200" href={whatsappLink} target="_blank" rel="noreferrer">WhatsApp</a>
            <a class="rounded-full border border-white/15 px-4 py-2 text-sm font-semibold text-white hover:bg-white/5" href={instagramLink} target="_blank" rel="noreferrer">Instagram</a>
          </div>
        </div>
      </div>
    </section>
  </main>
</BaseLayout>
