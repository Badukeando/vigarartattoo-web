---
import BaseLayout from "../layouts/BaseLayout.astro";
import GalleryLightbox from "./GalleryLightbox.astro";
import { worksRouteAlternates } from "../data/routeAlternates";
import {
  portfolioByCategory,
  blackworkItems,
  colorItems,
  fineLineItems,
  variosItems,
  petsItems,
  getPortfolioAlt,
} from "../data/portfolio";
import { worksPageContent } from "../data/worksPage";
import { instagramLink, whatsappLink, type SiteLang } from "../data/site";

const { lang } = Astro.props as { lang: SiteLang };

const content = worksPageContent[lang];
const isEn = lang === "en";
const alternatePaths = worksRouteAlternates;
const baseLangPill = "rounded-full border border-white/10 px-3 py-1 hover:bg-white/5";
const activeLangPill = "bg-white/10 text-white";
const curatedByCategory = {
  blackwork: blackworkItems,
  color: colorItems,
  "fine-line": fineLineItems,
  pets: petsItems,
  varios: variosItems,
} as const;
---

<BaseLayout
  lang={lang}
  title={content.seo.title}
  description={content.seo.description}
  ogImage={content.seo.ogImage}
  canonicalPath={alternatePaths[lang]}
  alternatePaths={alternatePaths}
>
  <main class="mx-auto max-w-6xl px-4">
    <div class="sticky-header pointer-events-none fixed left-0 right-0 top-0 z-[60] hidden" data-sticky-header data-hide-on-lightbox>
      <div class="mx-auto max-w-6xl px-4 pt-3">
        <div class="pointer-events-auto relative flex items-center gap-4 rounded-full glass-strong px-4 py-2">
          <a href={content.nav.brandHref} class="relative z-10 shrink-0 !bg-transparent text-base font-semibold tracking-wide text-glass hover:!bg-transparent focus:!bg-transparent">
            Vigarartattoo
          </a>

          <nav class="hidden min-w-0 flex-1 items-center justify-center gap-3 pl-2 text-sm text-zinc-200 md:flex text-glass" data-section-nav>
            {content.categories.map((category) => (
              <a class="nav-pill hover:text-white border border-transparent rounded-full px-2 py-1" href={`#${category.key}`} data-section-link={category.key}>
                {category.title}
              </a>
            ))}
          </nav>

          <div class="ml-auto flex shrink-0 items-center gap-2">
            <div class="hidden md:flex items-center gap-2 text-xs text-zinc-300">
              <a data-lang-link="es" class={`${baseLangPill} ${!isEn ? activeLangPill : ""}`} href={alternatePaths.es} aria-current={!isEn ? "page" : undefined}>ES</a>
              <a data-lang-link="en" class={`${baseLangPill} ${isEn ? activeLangPill : ""}`} href={alternatePaths.en} aria-current={isEn ? "page" : undefined}>EN</a>
            </div>

            <a class="rounded-full border border-white/15 bg-white/5 px-3 py-1.5 text-sm font-semibold text-white hover:bg-white/10" href={whatsappLink} target="_blank" rel="noreferrer">
              {content.nav.cta}
            </a>
          </div>
        </div>
      </div>
    </div>

    <header class="relative flex items-center justify-between py-6">
      <a href={content.nav.brandHref} class="text-lg font-semibold tracking-wide">Vigarartattoo</a>

      <div class="md:hidden absolute left-1/2 -translate-x-1/2 flex items-center gap-2 text-xs text-zinc-300">
        <a data-lang-link="es" class={`${baseLangPill} ${!isEn ? activeLangPill : ""}`} href={alternatePaths.es} aria-current={!isEn ? "page" : undefined}>ES</a>
        <a data-lang-link="en" class={`${baseLangPill} ${isEn ? activeLangPill : ""}`} href={alternatePaths.en} aria-current={isEn ? "page" : undefined}>EN</a>
      </div>

      <nav class="hidden items-center gap-6 text-sm text-zinc-300 md:flex" data-section-nav>
        {content.categories.map((category) => (
          <a class="nav-pill hover:text-white" href={`#${category.key}`} data-section-link={category.key}>
            {category.title}
          </a>
        ))}
      </nav>

      <div class="flex items-center gap-3 md:hidden">
        <button
          type="button"
          class="inline-flex items-center justify-center rounded-2xl border border-white/15 bg-white/5 px-4 py-2 text-sm font-semibold text-white hover:bg-white/10"
          aria-label={content.nav.menuOpenLabel}
          data-menu-open
        >
          {content.nav.menuButton}
        </button>
      </div>

      <div class="hidden items-center gap-2 text-sm text-zinc-300 md:flex">
        <a data-lang-link="es" class={`${baseLangPill} ${!isEn ? activeLangPill : ""}`} href={alternatePaths.es} aria-current={!isEn ? "page" : undefined}>ES</a>
        <a data-lang-link="en" class={`${baseLangPill} ${isEn ? activeLangPill : ""}`} href={alternatePaths.en} aria-current={isEn ? "page" : undefined}>EN</a>
      </div>

      <div class="menu-overlay fixed inset-0 z-50 hidden md:hidden" data-menu-overlay aria-hidden="true">
        <button class="menu-backdrop absolute inset-0 bg-black/70" aria-label={content.nav.menuCloseLabel} data-menu-close type="button"></button>

        <div class="menu-panel absolute right-0 top-0 h-full w-[85%] max-w-sm border-l border-white/10 bg-zinc-950 p-6">
          <div class="flex items-center justify-between">
            <div class="text-lg font-semibold">Vigarartattoo</div>
            <button
              type="button"
              class="rounded-2xl border border-white/15 bg-white/5 px-4 py-2 text-sm font-semibold text-white hover:bg-white/10"
              aria-label={content.nav.menuCloseLabel}
              data-menu-close
            >
              {content.nav.menuClose}
            </button>
          </div>

          <nav class="mt-8 grid gap-4 text-base">
            {content.categories.map((category) => (
              <a class="rounded-2xl border border-white/10 bg-white/5 px-4 py-3 hover:bg-white/10" href={`#${category.key}`} data-menu-link>
                {category.title}
              </a>
            ))}

            {lang === "en" ? (
              <div class="mt-2 grid grid-cols-2 gap-3">
                <a data-lang-link="es" class={baseLangPill} href={alternatePaths.es} aria-current={isEn ? undefined : "page"}>ES</a>
                <a data-lang-link="en" class={`${baseLangPill} ${isEn ? activeLangPill : ""}`} href={alternatePaths.en} aria-current={isEn ? "page" : undefined}>EN</a>
              </div>
            ) : null}

            <a class="mt-3 rounded-2xl bg-white px-4 py-3 text-center font-semibold text-zinc-950 hover:bg-zinc-200" href={whatsappLink} target="_blank" rel="noreferrer">
              {content.nav.whatsappCta}
            </a>

            <a class="rounded-2xl border border-white/10 bg-white/5 px-4 py-3 text-center hover:bg-white/10" href={instagramLink} target="_blank" rel="noreferrer">
              Instagram
            </a>
          </nav>
        </div>
      </div>
    </header>

    <section id="top" class="relative overflow-hidden rounded-3xl border border-white/10 bg-zinc-950">
      <img src={content.hero.imageSrc} alt={content.hero.imageAlt} class="absolute inset-0 h-full w-full object-cover" loading="eager" decoding="async" fetchpriority="high" />
      <div class="absolute inset-0 bg-gradient-to-r from-black/85 via-black/60 to-black/25"></div>
      <div class="absolute inset-0 backdrop-blur-[1px]"></div>

      <div class="relative px-6 py-16 md:px-12 md:py-20">
        <p class="text-xs uppercase tracking-[0.35em] text-zinc-200/80">{content.hero.eyebrow}</p>
        <h1 class="mt-4 text-4xl font-semibold leading-tight text-white md:text-6xl">{content.hero.title}</h1>
        <p class="mt-6 max-w-2xl text-base text-zinc-200 md:text-lg">{content.hero.description}</p>
      </div>
    </section>

    <div class="space-y-20 pb-20 pt-12">
      {content.categories.map((category) => {
        const sourceItems = curatedByCategory[category.key] ?? portfolioByCategory[category.key] ?? [];
        const items = sourceItems.map((item) => ({ ...item, alt: getPortfolioAlt(item, lang) }));

        return (
          <section id={category.key} class="scroll-mt-32 reveal">
            <header class="mb-6 flex flex-col gap-3 md:flex-row md:items-end md:justify-between">
              <div>
                <h2 class="text-2xl font-semibold md:text-3xl">{category.title}</h2>
                <p class="mt-2 text-sm text-zinc-400">{category.desc}</p>
              </div>

              {category.landingHref && category.landingLabel ? (
                <a class="text-sm text-zinc-300 hover:text-white" href={category.landingHref}>{category.landingLabel}</a>
              ) : null}
            </header>

            <GalleryLightbox items={items} galleryId={`works-${category.key}`} />
          </section>
        );
      })}
    </div>

    <div class="border-t border-white/10 pt-8 text-sm text-zinc-400">
      <div class="flex flex-wrap gap-4">
        <a class="hover:text-white" href={lang === "es" ? "/faq" : "/en/faq"}>{lang === "es" ? "FAQ tatuajes" : "Tattoo FAQ"}</a>
        <a class="hover:text-white" href={lang === "es" ? "/cuidados-tatuaje" : "/en/tattoo-aftercare"}>{lang === "es" ? "Cuidados del tatuaje" : "Tattoo aftercare"}</a>
        <a class="hover:text-white" href={lang === "es" ? "/estudio-tatuajes-malaga" : "/en/tattoo-studio-malaga"}>{lang === "es" ? "Estudio en Málaga" : "Studio in Malaga"}</a>
      </div>
    </div>
    <footer class="py-8 text-sm text-zinc-500">© {new Date().getFullYear()} {content.footerBrand}</footer>
  </main>
</BaseLayout>
